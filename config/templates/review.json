{
  "name": "review",
  "description": "Cross-review workflow: implement (Codex) → review (Claude)",
  "tasks": [
    {
      "id": "t1",
      "type": "implement",
      "promptTemplate": "Implement: {{prompt}}",
      "dependsOn": []
    },
    {
      "id": "t2",
      "type": "review",
      "promptTemplate": "Review the following implementation for bugs, security, and improvements:\n{{t1.output}}",
      "dependsOn": ["t1"]
    }
  ]
}
